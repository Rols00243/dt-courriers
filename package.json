{
  "name": "dt-courriers",
  "version": "0.1.0",
  "private": true,
  "description": "DT Courriers — Système de suivi et archivage des courriers avec IA",
  "author": {
    "name": "DT Courriers"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "icons": "node scripts/generate-icons.js",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c blue,yellow \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:compile && cross-env NODE_ENV=development electron .\"",
    "electron:start": "npm run electron:compile && electron .",
    "dist:prepare": "cross-env BUILD_TARGET=electron next build && npm run electron:compile",
    "dist:win": "npm run dist:prepare && electron-builder --win --x64",
    "dist:win-portable": "npm run dist:prepare && electron-builder --win --x64 -c.win.target=portable",
    "dist:dir": "npm run dist:prepare && electron-builder --win --dir",
    "dist:package": "npm run dist:prepare && node scripts/package-app.js",
    "dist:manual": "npm run dist:prepare && powershell -ExecutionPolicy Bypass -File scripts/manual-package.ps1"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "openai": "^6.39.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.76.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "tree-kill": "^1.2.2",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2",
    "use-debounce": "^10.1.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/wait-on": "^5.3.4",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
