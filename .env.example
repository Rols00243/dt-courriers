# Copiez ce fichier en `.env` et remplissez les valeurs réelles.
# .env est ignoré par Git — ne JAMAIS commiter de secrets.

# ─── Base de données PostgreSQL ─────────────────────────────────────
# Neon : https://console.neon.tech/ → votre projet → Connection details → Pooled
DATABASE_URL="postgresql://USER:PASSWORD@HOST.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth (authentification) ────────────────────────────────────
# Générez un secret long et aléatoire : `openssl rand -base64 32`
NEXTAUTH_SECRET="changez-moi-en-un-secret-long-et-aleatoire"

# URL publique de l'app (modifier après déploiement Vercel)
NEXTAUTH_URL="http://localhost:3000"

# Indispensable derrière un reverse proxy (Vercel, Cloudflare, etc.)
AUTH_TRUST_HOST="true"

# ─── Uploads de fichiers ────────────────────────────────────────────
UPLOAD_DIR="./public/uploads"

# ─── OpenAI (analyse IA des documents) ──────────────────────────────
# Clé API : https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
OPENAI_MODEL="gpt-4o-mini"

# ─── Emails (optionnel) ─────────────────────────────────────────────
# Resend : 100 emails/jour gratuits — https://resend.com/api-keys
# Sans clé, les emails sont juste loggués (pas d'erreur, juste un no-op)
RESEND_API_KEY=""
EMAIL_FROM="DT Courriers <onboarding@resend.dev>"
