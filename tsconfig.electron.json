{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "sourceMap": false,
    "declaration": false,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": false
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["node_modules", ".next", "out", "dist", "dist-electron"]
}
