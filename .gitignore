# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# electron build outputs (mais on garde build/icon.* + build/license.txt en source)
/dist
/dist-electron
/build/icon.png
/build/icon.ico

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env contient des secrets, .env.example OK à commiter
.env
.env.local
.env.*.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# logs locaux temporaires
/server-test.log
/package-log.txt
/electron-launch.log

# uploads des utilisateurs (en prod ces fichiers vivent ailleurs)
/public/uploads/*
!/public/uploads/.gitkeep
